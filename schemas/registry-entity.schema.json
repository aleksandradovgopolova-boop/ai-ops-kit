{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-ops-kit.dev/schemas/registry-entity.schema.json",
  "title": "RegistryEntity",
  "description": "Generic structured registry entity (agent/skill/template). Encodes agent-registry contract fields (Section 23).",
  "type": "object",
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string" },
    "version": { "type": "string" },
    "contract_version": { "type": "integer" },
    "entity_type": { "type": "string", "enum": ["agent", "skill", "template", "workflow", "gate"] },
    "layer": { "type": "string", "enum": ["core", "preset", "project", "custom", "generated", "parent-only"] },
    "preset": { "type": ["string", "null"] },
    "file": { "type": "string" },
    "reuse_of": { "type": ["array", "null"], "items": { "type": "string" } },
    "purpose": { "type": "string" },
    "triggers": { "type": "array", "items": { "type": "string" } },
    "reads": { "type": "array", "items": { "type": "string" } },
    "writes": { "type": "array", "items": { "type": "string" } },
    "uses_skills": { "type": "array", "items": { "type": "string" } },
    "follows_rules": { "type": "array", "items": { "type": "string" } },
    "uses_templates": { "type": "array", "items": { "type": "string" } },
    "participates_in_workflows": { "type": "array", "items": { "type": "string" } },
    "required_capabilities": { "type": "array", "items": { "type": "string" } },
    "write_scope": { "type": "array", "items": { "type": "string" } },
    "completion_criteria": { "type": "string" },
    "hands_off_to": { "type": "array", "items": { "type": "string" } },
    "quality_gates": { "type": "array", "items": { "type": "string" } },
    "review_mode": { "type": "string", "enum": ["writer", "read-only"] },
    "blocking_behavior": { "type": "string", "enum": ["blocking", "non-blocking"] },
    "supported_execution_modes": { "type": "array", "items": { "type": "string" } },
    "supported_adapters": { "type": "array", "items": { "type": "string" } },
    "deprecation": { "type": ["object", "null"] }
  },
  "required": ["schema_version", "id", "entity_type", "layer", "file", "purpose", "review_mode"],
  "additionalProperties": true,
  "x-invariant": "If review_mode == 'read-only', write_scope MUST NOT overlap the reviewed artifact (validator-enforced).",
  "examples": [
    {
      "schema_version": 1,
      "id": "requirements-reviewer",
      "version": "2.0.0",
      "contract_version": 1,
      "entity_type": "agent",
      "layer": "core",
      "preset": null,
      "file": "core/agents/requirements-reviewer.md",
      "reuse_of": ["agents/quality/requirements-reviewer.md"],
      "purpose": "Read-only critique of requirements",
      "reads": ["change/requirements.md"],
      "writes": ["change/gates/requirements.gate.json"],
      "participates_in_workflows": ["ENGINEERING", "PRODUCT"],
      "write_scope": ["change/gates/requirements.gate.json"],
      "review_mode": "read-only",
      "blocking_behavior": "blocking",
      "supported_execution_modes": ["native", "orchestrated", "sequential"],
      "supported_adapters": ["claude-code", "codex", "gigachat", "generic"],
      "deprecation": null
    }
  ]
}
